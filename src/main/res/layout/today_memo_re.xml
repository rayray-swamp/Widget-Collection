<?xml version="1.0" encoding="utf-8"?>
<ViewFlipper
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:inAnimation="@anim/slide_in_right"
    android:id="@+id/today_memo_dialog_re_vf">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/today_memo_dialog_re_back_ll">
                <TextView
                    android:layout_width="25dp"
                    android:layout_height="wrap_content"
                    android:id="@+id/today_memo_dialog_re_back"
                    android:textSize="@dimen/calendar_today_memo_re_title_size"
                    android:text="&lt;"
                    android:gravity="center"
                    android:textColor="@color/black" />
            </LinearLayout>
            <Space
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/today_memo_dialog_re_title"
                android:textSize="@dimen/calendar_today_memo_re_title_size"
                android:gravity="center"
                android:textColor="@color/black"
                android:paddingRight="10dp"
                android:paddingLeft="10dp"
                android:background="@drawable/frame_style"/>
            <Space
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/today_memo_dialog_re_next_ll">
                <TextView
                    android:layout_width="25dp"
                    android:layout_height="wrap_content"
                    android:id="@+id/today_memo_dialog_re_next"
                    android:textSize="@dimen/calendar_today_memo_re_title_size"
                    android:text=">"
                    android:gravity="center"
                    android:textColor="@color/black"/>
            </LinearLayout>
        </LinearLayout>
        <ViewFlipper
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inAnimation="@anim/scale_in_fast"
            android:id="@+id/today_memo_dialog_re_vf2">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:id="@+id/today_memo_dialog_re_fr"
                    android:layout_centerInParent="true">
                </FrameLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_centerInParent="true"
                    android:id="@+id/today_memo_dialog_re_ll"
                    android:orientation="horizontal"
                    android:visibility="gone">
                    <com.aigestudio.wheelpicker.WheelPicker
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:id="@+id/today_memo_dialog_re_np1"
                        android:layout_marginLeft="25dp"/>
                    <com.aigestudio.wheelpicker.WheelPicker
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:id="@+id/today_memo_dialog_re_np2"
                        android:layout_marginRight="25dp"/>
                </LinearLayout>
            </RelativeLayout>
        </ViewFlipper>

    </LinearLayout>
</ViewFlipper>

