<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 枠線 width:線の幅、color:線の色 -->
    <item
        android:left="-5dp"
        android:right="-5dp">
        <shape>
            <solid android:color="#DD2C00" />
            <stroke
                android:width="1dp"
                android:color="#000000" />
            <padding
                android:left="-30dp"
                android:right="-30dp"/>
        </shape>

    </item>

</layer-list>